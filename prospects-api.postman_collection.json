{
    "info": {
        "name": "Hillpointe CRM — Prospects API",
        "_postman_id": "b2e4c1d0-9f3a-4e1b-8c2d-prospects0001",
        "description": "CRUD + status transition endpoints for the Prospects resource. Run requests in order — early requests save IDs into collection variables used by later ones.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3001",
            "type": "string"
        },
        {
            "key": "prospectId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "1. List all prospects",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/prospects",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "prospects"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Status 200', () => pm.response.to.have.status(200));",
                            "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "2. Filter by status=new",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/prospects?status=new",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "prospects"
                    ],
                    "query": [
                        {
                            "key": "status",
                            "value": "new"
                        }
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Status 200', () => pm.response.to.have.status(200));",
                            "const body = pm.response.json();",
                            "pm.test('All items have status=new', () => body.forEach(p => pm.expect(p.status).to.eql('new')));"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "3. Create prospect",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/api/prospects",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "prospects"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Jordan Hayes\",\n  \"email\": \"jordan.hayes@example.com\",\n  \"phone\": \"(555) 200-0001\",\n  \"status\": \"new\"\n}"
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Status 201', () => pm.response.to.have.status(201));",
                            "const body = pm.response.json();",
                            "pm.test('Has id', () => pm.expect(body.id).to.be.a('string'));",
                            "pm.test('Status is new', () => pm.expect(body.status).to.eql('new'));",
                            "pm.collectionVariables.set('prospectId', body.id);"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "4. Create prospect — duplicate email (expect 409)",
            "request": {
                "method": "POST",
                "header": [
                    {
