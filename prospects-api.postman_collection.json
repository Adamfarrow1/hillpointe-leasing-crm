                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Jordan Hayes 2\",\n  \"email\": \"jordan.hayes@example.com\",\n  \"phone\": \"(555) 200-0099\"\n}"
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Status 409', () => pm.response.to.have.status(409));"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
