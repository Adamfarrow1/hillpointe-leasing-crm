                        "exec": [
                            "pm.test('Status 200', () => pm.response.to.have.status(200));",
                            "pm.test('ID matches', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('prospectId')));"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
