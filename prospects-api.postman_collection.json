                            "pm.test('Has issues array', () => pm.expect(pm.response.json().issues).to.be.an('array'));"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "6. Get prospect by ID",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/prospects/{{prospectId}}",
