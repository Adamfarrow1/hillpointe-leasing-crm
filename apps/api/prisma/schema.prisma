generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Unit {
  id         String  @id @default(cuid())
  unitNumber String  @unique
  status     String  @default("available")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
